# Agent Hub Configuration
AGENTHUB_HOST=0.0.0.0
AGENTHUB_PORT=7788

# Database
AGENTHUB_DB_PATH=./data/state/agenthub.db

# Storage  
AGENTHUB_ARTIFACT_DIR=./data/artifacts
AGENTHUB_ZVEC_PATH=./data/zvec

# Cache
REDIS_URL=redis://localhost:6379

# Security
AGENTHUB_SECRET_KEY=your-secret-key-here-change-in-production
AGENTHUB_API_KEYS_FILE=./data/state/api_keys.json

# Logging
AGENTHUB_LOG_LEVEL=INFO
AGENTHUB_LOG_FILE=./logs/agenthub.log

# Task Configuration
AGENTHUB_TASK_LEASE_TTL_SEC=300
AGENTHUB_MAX_AGENTS=100
AGENTHUB_MAX_CONCURRENT_TASKS=50

# Vector Search
AGENTHUB_VECTOR_BATCH_SIZE=1000
AGENTHUB_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Cleanup
AGENTHUB_EVENT_RETENTION_DAYS=30
AGENTHUB_MESSAGE_RETENTION_DAYS=90